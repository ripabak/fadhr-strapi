{
  "kind": "collectionType",
  "collectionName": "catalogs",
  "info": {
    "singularName": "catalog",
    "pluralName": "catalogs",
    "displayName": "Catalog",
    "description": "Product catalog entries"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "title": {
      "type": "string",
      "required": true
    },
    "year": {
      "type": "string"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "link": {
      "type": "string"
    },
    "useCoverImg": {
      "type": "boolean",
      "private": true,
      "required": true,
      "default": false
    },
    "bgColorHex": {
      "type": "string",
      "conditions": {
        "visible": {
          "!=": [
            {
              "var": "useCoverImg"
            },
            true
          ]
        }
      },
      "default": "#ffffff",
      "required": true,
      "regex": "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    },
    "cover": {
      "type": "media",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "useCoverImg"
            },
            true
          ]
        }
      },
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "badgeText": {
      "type": "string"
    },
    "actionText": {
      "type": "string"
    }
  }
}
