{
  "kind": "collectionType",
  "collectionName": "catalogs",
  "info": {
    "singularName": "catalog",
    "pluralName": "catalogs",
    "displayName": "Catalog",
    "description": "Product catalog entries"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "year": {
      "type": "string"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "link": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "videos"]
    },
    "badgeText": {
      "type": "string"
    },
    "actionText": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "default": "bg-neutral-800 text-white"
    },
    "darkGradient": {
      "type": "boolean",
      "default": false
    }
  }
}
